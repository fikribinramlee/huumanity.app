{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "selector"
  ],
  "remote": {
    "urls": [
      "https://huumanity.app",
      "https://huumanity.app/*"
    ]
  },
  "permissions": [
    "core:default",
    "deep-link:default",
    "opener:default",
    "allow-app-commands"
  ]
}
